+// 제안 대체 로그 엔트리를 만든다.
+static JsonObject ProposalSupersededLog(string proposalId, string reasonCode)
+{
+    return new JsonObject
+    {
+        ["event"] = "proposal.superseded",
+        ["params"] = new JsonObject { ["proposalId"] = proposalId, ["reasonCode"] = reasonCode },
