dinalIgnoreCase))\r\n  105:             return RunSelfTest();\r\n  106:         Console.Error.WriteLine(\"{\\\"error\\\":\\\"state-transition usage: prepare --transition-id <id> --request <file> | apply --envelope <file> | --self-test\\\"}\");\r\n  107:         return 2;\r\n  108:     }\r\n  109: \r\n  110:     // prepare: 옵션을 검증하고 root를 찾아 RunPrepareCore에 위임한다.\r\n  111:     private static int RunPrepare(string[] args)\r\n  112:     {\r\n  113:         var optErr = ValidateOptions(ParseFlagMap(args, 2), PrepareKnownKeys);\r\n  114:         if (optErr is not null) { Console.Error.WriteLine($\"{{\\\"error\\\":\\\"{optErr}\\\"}}\"); return 2; }\r\n  115:         var opts = ParsePrepareArgs(args);\r\n  116:         if (opts is null)\r\n  117:         {\r\n  118:             Console.Error.WriteLine(\"{\\\"error\\\":\\\"prepare에는 --transition-id, --request 가 필요합니다\\\"}\");\r\n  119:             return 2;\r\n  120:         }\r\n  121:         try { return RunPrepareCore(GitTools.FindRepoRoot(), opts); }\r\n  122:         catch (Exception ex) { Console.Error.WriteLine($\"{{\\\"error\\\":\\\"state-transition prepare 실패: {ex.Message}\\\"}}\"); return 2; }\r\n  123:     }\r\n  124: \r\n  125:     // prepare 핵심 — root를 명시적으로 받아 자기 시험과 production 경로 공유.\r\n  126:     private static int RunPrepareCore(string root, PrepareOptions opts)\r\n  127:     {\r\n  128:         var workstatePath = Path.Combine(root, \"docs\", \"handoff\", \"WORKSTATE.json\");\r\n  129:         if (!File.Exists(workstatePath)) { WriteError(\"WORKSTATE.json not found\"); return 2; }\r\n  130: \r\n  131:         var rawWorkstate = File.ReadAllText(workstatePath, new UTF8Encoding(false));\r\n  132:         var workstate = JsonNode.Parse(rawWorkstate)?.AsObject();\r\n  133:         if (workstate is null) { WriteError(\"WORKSTATE.json is not a valid JSON object\"); return 2; }\r\n  134: \r\n  135:         if (!File.Exists(opts.RequestPath)) { WriteError($\"request file not found: {opts.RequestPath}\"); return 2; }\r\n  136:         var rawRequest = File.ReadAllText(opts.RequestPath, new UTF8Encoding(false));\r\n  137:         var request = JsonNode.Parse(rawRequest)?.AsObject();\r\n  138:         if (request is null) { WriteError(\"request JSON must be a JSON object\"); return 2; }\r\n  139: \r\n  140:         // 해시 계산 + effectiveAt 발급 (NORMAL은 prepare가 현재 UTC를 발급, 외부 플래그 없음).\r\n  141:         var preStateSha256 = ComputeSha256(rawWorkstate);\r\n  142:         var requestSha256 = ComputeSha256(rawRequest);\r\n  143:         var effectiveAt = DateTime.UtcNow.ToString(\"o\");\r\n  144: \r\n  145:         // 결정적 candidate 계산 — UtcNow 호출 없이 effectiveAt을 파라미터로 받는다.\r\n  146:         var candidate = BuildCandidate(workstate, request, opts.TransitionId, effectiveAt);\r\n  147:         var candidateBytes = Encoding.UTF8.GetBytes(candidate.ToJsonString(WriteOptions));\r\n  148:         var postStateSha256 = Convert.ToHexString(SHA256.HashData(candidateBytes)).ToLowerInvariant();\r\n  149:         var contractHash = ComputeContractHash(\r\n  150:             opts.TransitionId, \"NORMAL\", requestSha256, preStateSha256, postStateSha256, effectiveAt);\r\n  151: \r\n  152:         if (opts.DryRun)\r\n  153:         {\r\n  154:             Console.WriteLine(new JsonObject\r\n  155:             {\r\n  156:                 [\"ok\"] = true, [\"dryRun\"] = true,\r\n  157:                 [\"transitionId\"] = opts.TransitionId,\r\n  158:                 [\"preStateSha256\"] = preStateSha256,\r\n  159:                 [\"expectedPostStateSha256\"] = postStateSha256,\r\n  160:                 [\"transitionContractSha256\"] = contractHash,\r\n  161:             }.ToJsonString(WriteOptions));\r\n  162:             return 0;\r\n  163:         }\r\n  164: \r\n  165:         return WritePrepareOutput(root, opts, preStateSha256, requestSha256, postStateSha256, contractHash, candidateBytes, effectiveAt);\r\n  166:     }\r\n  167: \r\n  168:     // envelope+candidate 파일을 outputs/state-transition/에 기