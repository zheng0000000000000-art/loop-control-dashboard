+  return {
+    id: `review-${Date.now()}`,
+    proposalId: proposal.id,
+    verdict,
+    reviewer: { type: "human", provider: "human", model: null },
+    riskAssessed,
+    findings: Array.isArray(findings) ? findings : [],
+    reason,
+    createdAt,
+  };
+}
