uestPath, new UTF8Encoding(false));\r\n  137:         var request = JsonNode.Parse(rawRequest)?.AsObject();\r\n  138:         if (request is null) { WriteError(\"request JSON must be a JSON object\"); return 2; }\r\n  139: \r\n  140:         // 해시 계산 + effectiveAt 발급 (NORMAL은 prepare가 현재 UTC를 발급, 외부 플래그 없음).\r\n  141:         var preStateSha256 = ComputeSha256(rawWorkstate);\r\n  142:         var requestSha256 = ComputeSha256(rawRequest);\r\n  143:         var effectiveAt = DateTime.UtcNow.ToString(\"o\");\r\n  144: \r\n  145:         // 결정적 candidate 계산 — UtcNow 호출 없이 effectiveAt을 파라미터로 받는다.\r\n  146:         var candidate = BuildCandidate(workstate, request, opts.TransitionId, effectiveAt);\r\n  147:         var candidateBytes = Encoding.UTF8.GetBytes(candidate.ToJsonString(WriteOptions));\r\n  148:         var postStateSha256 = Convert.ToHexString(SHA256.HashData(candidateBytes)).ToLowerInvariant();\r\n  149:         var contractHash = ComputeContractHash(\r\n  150:             opts.TransitionId, \"NORMAL\", requestSha256, preStateSha256, postStateSha256, effectiveAt);\r\n  151: \r\n  152:         if (opts.DryRun)\r\n  153:         {\r\n  154:             Console.WriteLine(new JsonObject\r\n  155:             {\r\n  156:                 [\"ok\"] = true, [\"dryRun\"] = true,\r\n  157:                 [\"transitionId\"] = opts.TransitionId,\r\n  158:                 [\"preStateSha256\"] = preStateSha256,\r\n  159:                 [\"expectedPostStateSha256\"] = postStateSha256,\r\n  160:                 [\"transitionContractSha256\"] = contractHash,\r\n  161:             }.ToJsonString(WriteOptions));\r\n  162:             return 0;\r\n  163:         }\r\n  164: \r\n  165:         return WritePrepareOutput(root, opts, preStateSha256, requestSha256, postStateSha256, contractHash, candidateBytes, effectiveAt);\r\n  166:     }\r\n  167: \r\n  168:     // envelope+candidate 파일을 outputs/state-transition/에 기록하고 결과를 출력한다.\r\n  169:     private static int WritePrepareOutput(\r\n  170:         string root, PrepareOptions opts, string preStateSha256, string requestSha256,\r\n  171:         string postStateSha256, string contractHash, byte[] candidateBytes, string effectiveAt)\r\n  172:     {\r\n  173:         var outDir = Path.Combine(root, \"outputs\", \"state-transition\");\r\n  174:         Directory.CreateDirectory(outDir);\r\n  175:         var safeTid = Regex.Replace(opts.TransitionId, @\"[^\\w\\-]\", \"_\");\r\n  176: \r\n  177:         // candidate 파일 기록 — evidence용. apply는 이 파일을 canonical write에 쓰지 않는다.\r\n  178:         var candidatePath = Path.Combine(outDir, $\"{safeTid}.candidate.json\");\r\n  179:         File.WriteAllBytes(candidatePath, candidateBytes);\r\n  180: \r\n  181:         var envelope = new JsonObject\r\n  182:         {\r\n  183:             [\"schemaVersion\"] = 1,\r\n  184:             [\"transitionKind\"] = \"NORMAL\",\r\n  185:             [\"transitionId\"] = opts.TransitionId,\r\n  186:             [\"expectedPreStateSha256\"] = preStateSha256,\r\n  187:             [\"requestPath\"] = opts.RequestPath,\r\n  188:             [\"requestSha256\"] = requestSha256,\r\n  189:             [\"effectiveAt\"] = effectiveAt,\r\n  190:             [\"expectedPostStateSha256\"] = postStateSha256,\r\n  191:             [\"transitionContractSha256\"] = contractHash,\r\n  192:             [\"candidatePath\"] = candidatePath,\r\n  193:         };\r\n  194: \r\n  195:         var envelopePath = Path.Combine(outDir, $\"{safeTid}.envelope.json\");\r\n  196:         File.WriteAllText(envelopePath, envelope.ToJsonString(WriteOptions), new UTF8Encoding(false));\r\n  197: \r\n  198:         Console.WriteLine(new JsonObject\r\n  199:         {\r\n  200:             [\"ok\"] = true,\r\n  201:             [\"transitionId\"] = opts.TransitionId,\r\n  202:             [\"envelopePath\"] = envelopePath,\r\n  203:             [\"candidatePath\"] = candidatePath,\r\n  204:             [\"preStateSha256\"] = preStateSha256,\r\n  205: 