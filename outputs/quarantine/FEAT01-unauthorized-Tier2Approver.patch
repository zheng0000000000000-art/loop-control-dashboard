+    // AI 반입 결과를 프로젝트 run-log에 import.ai 이벤트로 기록한다.
+    private void WriteImportAiEvent(string projectId, string taskId, JsonObject tier2, int dailyCount, string outcome, int violationsBefore)
+    {
+        if (string.IsNullOrWhiteSpace(projectId))
+        {
+            return;
+        }
+
+        try
+        {
+            var dataRoot = Path.Combine(workspaceRoot, "dashboard", "data");
+            var storage = new Storage(dataRoot);
+            lock (storage.GetProjectLock(projectId))
+            {
+                var runLog = storage.ReadProjectFile(projectId, Storage.RunLogFile).AsObject();
+                var state = storage.ReadProjectFile(projectId, Storage.StateFile).AsObject();
+                var updated = Engine.AppendLog(
+                    runLog,
+                    new JsonObject
+                    {
+                        ["event"] = "import.ai",
+                        ["params"] = new JsonObject
+                        {
+                            ["taskId"] = taskId,
+                            ["outcome"] = outcome,
+                            ["gateEligible"] = tier2["eligible"]?.GetValue<bool>() ?? false,
+                            ["eligibilityReasons"] = tier2["eligibilityReasons"]?.DeepClone() ?? new JsonArray(),
+                            ["reviewer"] = new JsonObject
+                            {
+                                ["provider"] = Options.Provider,
+                                ["model"] = tier2["reviewer"]?["model"]?.GetValue<string>(),
+                                ["verdict"] = tier2["reviewer"]?["verdict"]?.GetValue<string>(),
+                                ["reason"] = tier2["reviewer"]?["reason"]?.GetValue<string>(),
+                            },
+                            ["dailyCount"] = dailyCount,
+                            ["dailyCap"] = Options.DailyCap,
+                            ["tier"] = "tier2",
+                            ["violationsBefore"] = violationsBefore,
+                        },
+                        ["level"] = outcome == "approved" ? "info" : "warning",
+                        ["producedBy"] = new JsonObject
+                        {
+                            ["provider"] = Options.Provider,
+                            ["model"] = tier2["reviewer"]?["model"]?.GetValue<string>(),
+                        },
+                        ["cost"] = Tier2Cost(),
+                    },
+                    Engine.GetLoopIteration(state)
+                );
+                storage.WriteProjectFile(projectId, Storage.RunLogFile, updated);
+            }
+        }
+        catch
+        {
+            // run-log 이벤트 기록 실패는 반입 결과에 영향 없다 — 감사 로그로 확인 가능.
+        }
+    }
+
+    // 이상 감지 시 롤백 요청 파일을 task 디렉터리에 생성한다.
+    private void WriteRollbackRequest(string taskDirectory, string taskId, JsonObject meta, int before, int after)
+    {
+        try
+        {
+            File.WriteAllText(
+                Path.Combine(taskDirectory, "rollback-request.json"),
+                new JsonObject
+                {
+                    ["requestedAt"] = DateTimeOffset.Now.ToString("O"),
+                    ["taskId"] = taskId,
+                    ["projectId"] = meta["projectId"]?.GetValue<string>() ?? "",
+                    ["reason"] = $"post-import violations increased: {before} -> {after}",
+                    ["changedFiles"] = meta["changedFiles"]?.DeepClone() ?? new JsonArray(),
+                    ["action"] = "revert_required",
+                }.ToJsonString(JsonOptions),
+                Encoding.UTF8);
+        }
+        catch
+        {
+            // rollback-request 파일 기록 실패는 무시한다 — halt 상태이므로 사람이 감사 로그로 확인한다.
+        }
+    }
+
+    // tier2 run-log 이벤트용 비용 0 객체를 만든다.
+    private static JsonObject Tier2Cost()
+    {
+        return new JsonObject
+        {
+            ["inputTokens"] = 0,
+            ["outputTokens"] = 0,
+            ["estimatedUSD"] = 0,
+            ["subscriptionCalls"] = 0,
+            ["role"] = "tier2",
+        };
+    }
