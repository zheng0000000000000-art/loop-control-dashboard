{"type":"item.completed","item":{"id":"item_16","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '[Console]::OutputEncoding=[Text.Encoding]::UTF8; $i=0; [IO.File]::ReadLines('\"'server/TrustOriginCli.cs',[Text.Encoding]::UTF8) | ForEach-Object { \"'$i++; '\"'{0,5}: {1}' -f \"'$i, $_ }'","aggregated_output":"    1: // trust-origin 신뢰 원점 부트스트랩 선언 CLI.\r\n    2: // declare: 선행 10조건 검사 후 trust-origin record를 생성한다. WORKSTATE·applier-log는 수정하지 않는다.\r\n    3: // --self-test: $TEMP 사본에서 5개 case를 in-process로 검증한다.\r\n    4: using System.Diagnostics;\r\n    5: using System.Security.Cryptography;\r\n    6: using System.Text;\r\n    7: using System.Text.Encodings.Web;\r\n    8: using System.Text.Json;\r\n    9: using System.Text.Json.Nodes;\r\n   10: \r\n   11: internal static class TrustOriginCli\r\n   12: {\r\n   13:     // record 고정 경로 — 이 밖 경로에는 절대 쓰지 않는다.\r\n   14:     private const string RecordRelPath = \"docs/handoff/trust-origin/TO-2026-001.json\";\r\n   15: \r\n   16:     private static readonly JsonSerializerOptions WriteOptions = new()\r\n   17:     {\r\n   18:         WriteIndented = true,\r\n   19:         Encoder = JavaScriptEncoder.UnsafeRelaxedJsonEscaping,\r\n   20:     };\r\n   21: \r\n   22:     // knownException 항목 데이터 레코드.\r\n   23:     private record KnownException(string Code, string Subject, string What, string Why, string WhyNotReplayed);\r\n   24: \r\n   25:     // 자기 시험 전용 precondition 주입 레코드 — CLI·환경변수로 켤 수 없음.\r\n   26:     internal record PreconOverride(\r\n   27:         bool BuildVerified, bool FilesTracked, bool NoDirectMod,\r\n   28:         string CommitHash, bool AutoLauncherOff, bool HighRiskClosed);\r\n   29: \r\n   30:     // 자기 시험 seam — in-process 훅만. production 진입점에서 설정 불가.\r\n   31:     internal static bool NonInteractiveOverride;\r\n   32:     internal static PreconOverride? TestPrecon;\r\n   33: \r\n   34:     // trust-origin 진입점.\r\n   35:     internal static int Run(string[] args)\r\n   36:     {\r\n   37:         var sub = args.Length > 1 ? args[1] : \"\";\r\n   38:         if (string.Equals(sub, \"declare\", StringComparison.OrdinalIgnoreCase))\r\n   39:             return RunDeclare(args);\r\n   40:         if (string.Equals(sub, \"--self-test\", StringComparison.OrdinalIgnoreCase))\r\n   41:             return RunSelfTest();\r\n   42:         Console.Error.WriteLine(\r\n   43:             \"{\\\"error\\\":\\\"trust-origin usage: declare --ack BOOTSTRAP_TRUST_ORIGIN [--known-exceptions-file <path>] | --self-test\\\"}\");\r\n   44:         return 2;\r\n   45:     }\r\n   46: \r\n   47:     // declare: 비대화형 거부(약한 안전장치), ack 확인, precondition 검사, record 생성.\r\n   48:     private static int RunDeclare(string[] args)\r\n   49:     {\r\n   50:         // 약한 안전장치(신원 증명 아님) — 비대화형 실행 기본 거부.\r\n   51:         // 프로그램은 사람과 AI를 구분 못 한다(HUMAN_DECLARED_NOT_CRYPTOGRAPHICALLY_VERIFIED).\r\n   52:         if (!NonInteractiveOverride && (Console.IsInputRedirected || !Environment.UserInteractive))\r\n   53:         {\r\n   54:             Console.Error.WriteLine(\r\n   55:                 \"{\\\"error\\\":\\\"비대화형 실행 기본 거부\\\",\\\"code\\\":\\\"non-interactive-rejected\\\",\"\r\n   56:                 + \"\\\"note\\\":\\\"HUMAN_DECLARED_NOT_CRYPTOGRAPHICALLY_VERIFIED — 프로그램은 사람과 AI를 구분하지 못합니다\\\"}\");\r\n   57:             return 1;\r\n   58:         }\r\n   59:         var map = ParseFlagMap(args, 2);\r\n   60:         if (!map.TryGetValue(\"ack\", out var ackVal) ||\r\n   61:             !string.Equals(ackVal, \"BOOTSTRAP_TRUST_ORIGIN\", StringComparison.OrdinalIgnoreCase))\r\n   62:         {\r\n   63:             Console.Error.WriteLine(\"{\\\"error\\\":\\\"--ack BOOTSTRAP_TRUST_ORIGIN 필요\\\",\\\"code\\\":\\\"ack-missing\\\"}\");\r\n   64:             return 1;\r\n   65:         }\r\n   66:         string root;\r\n   67:         try { root = GitTools.FindRepoRoot(); }\r\n   68:         catch (Exception ex) { WriteError($\"repo root 탐색 실패: {ex.Message}\"); return 2; }\r\n   69: \r\n   70:         List<KnownException> knownExceptions = [];\r\n   71:         if (map.TryGetValue(\"known-exceptions-file\", out var efile))\r\n   72:         {\r\n   73:             try { knownExceptions = ParseKnownExceptions(JsonNode.Parse(File.ReadAllText(efile, new UTF8Encoding(false)))); }\r\n   74:             catch (Exception ex) { WriteError($\"known-exceptions-file 읽기 실패: {ex.Message}\"); return 2; }\r\n   75:         }\r\n   76:         return RunDeclareCore(root, knownExceptions);\r\n   77:     }\r\n   78: \r\n   79:     // declare 핵심 — root를 명시적으로 받아 자기 시험과 production 경로를 공유한다.\r\n   80:     private static int RunDeclareCore(string root, List<KnownException> knownExceptions)\r\n   81:     {\r\n   82:         var recordPath = Path.GetFullPath(\r\n   83:             Path.Combine(root, RecordRelPath.Replace('/', Path.DirectorySeparatorChar)));\r\n   84:         var wsPath = Path.Combine(root, \"docs\", \"handoff\", \"WORKSTATE.json\");\r\n   85:         var logPath = Path.Combine(root, \"docs\", \"handoff\", \"WORKSTATE.applier-log.jsonl\");\r\n   86:         var precon = TestPrecon;\r\n   87: \r\n   88:         // 기존 epoch 확인: trustEpoch >= 1 이면 거부.\r\n   89:         var epochExit = CheckEpochGuard(recordPath);\r\n   90:         if (epochExit.HasValue) return epochExit.Value;\r\n   91: \r\n   92:         // WORKSTATE 읽기.\r\n   93:         if (!File.Exists(wsPath)) { WriteError(\"WORKSTATE.json not found\"); return 2; }\r\n   94:         string wsContent;\r\n   95:         try { wsContent = File.ReadAllText(wsPath, new UTF8Encoding(false)); }\r\n   96:         catch (Exception ex) { WriteError($\"WORKSTATE.json 읽기 실패: {ex.Message}\"); return 2; }\r\n   97: \r\n   98:         // 선행조건 2: reconciliation 실행 + 부분집합 검사.\r\n   99:         var (reconResult, reconExit) = RunReconciliationCheck(wsPath, logPath, knownExceptions);\r\n  100:         if (reconExit.HasValue) return reconExit.Value;\r\n  101: \r\n  102:         // 선행조건 1·3·4·9·10 검사.\r\n  103:         var preconExit = CheckAllPreconditions(root, precon);\r\n  104:         if (preconExit.HasValue) return preconExit.Value;\r\n  105: \r\n  106:         // 선행조건 5: WORKSTATE hash / 선행조건 6: applier-log hash.\r\n  107:         var workstateSha256 = ComputeSha256(wsContent);\r\n  108:         var logContent = File.Exists(logPath) ? File.ReadAllText(logPath, new UTF8Encoding(false)) : \"\";\r\n  109:         var applierLogSha256 = ComputeSha256(logContent);\r\n  110: \r\n  111:         // 선행조건 7: baseline commit hash.\r\n  112:         var (baselineCommit, commitExit) = GetBaselineCommit(root, precon);\r\n  113:         if (commitExit.HasValue) return commitExit.Value;\r\n  114: \r\n  115:         // record 생성 — declarationCommit 없음(자기참조 방지). 이 경로 외에는 쓰지 않는다.\r\n  116:         return BuildAndWriteRecord(\r\n  117:             recordPath, baselineCommit!, workstateSha256, applierLogSha256, reconResult!, knownExceptions);\r\n  118:     }\r\n  119: \r\n  120:     // 기존 epoch 확인 — trustEpoch >= 1 이면 exit 1, 없으면 null.\r\n  121:     private static int? CheckEpochGuard(string recordPath)\r\n  122:     {\r\n  123:         if (!File.Exists(recordPath)) return null;\r\n  124:         try\r\n  125:         {\r\n  126:             var existing = JsonNode.Parse(File.ReadAllText(recordPath))?.AsObject();\r\n  127:             if ((existing?[\"trustEpoch\"]?.GetValue<int>() ?? 0) >= 1)\r\n  128:             {\r\n  129:                 WriteError(\"trustEpoch >= 1 이미 존재 — 재선언 거부. 새 trust origin은 VERIFIED_HUMAN_APPROVAL receipt 필요\");\r\n  130:                 return 1;\r\n  131:             }\r\n  132:         }\r\n  133:         catch { /* 파싱 불가 시 아래 CreateNew에서 처리 */ }\r\n  134:         return null;\r\n  135:     }\r\n  136: \r\n  137:     // reconciliation을 실행하고 failure ⊆ knownExceptions 부분집합 검사를 수행한다.\r\n  138:     private static (ReconciliationResult? result, int? exitCode) RunReconciliationCheck(\r\n  139:         string wsPath, string logPath, List<KnownException> knownExceptions)\r\n  140:     {\r\n  141:         ReconciliationResult reconResult;\r\n  142:         try { reconResult = HandoffIntegrityChecker.Run(new ReconciliationOptions(wsPath, logPath)); }\r\n  143:         catch (Exception ex) { WriteError($\"reconciliation 실행 실패: {ex.Message}\"); return (null, 2); }\r\n  144: \r\n  145:         // 하네스 오류 시 별도 중단 — subject가 없어 부분집합 검사를 우회할 수 있다.\r\n  146:         if (reconResult.HarnessErrors.Count > 0)\r\n  147:         {\r\n  148:             var errs = string.Join(\"; \", reconResult.HarnessErrors.Select(e => e.Code));\r\n  149:             WriteError($\"reconciliation 하네스 오류 — 선행조건 2 검증 불가: {errs}\");\r\n  150:             return (null, 2);\r\n  151:         }\r\n  152: \r\n  153:         // 정확한 집합 검사: failures == knownExceptions. 미명시 failure 또는 extra known exception → 선언 거부.\r\n  154:         var failureSubjects = reconResult.Failures\r\n  155:             .Select(f => f.Subject).Where(s => !string.IsNullOrWhiteSpace(s))\r\n  156:             .ToHashSet(StringComparer.OrdinalIgnoreCase);\r\n  157:         var knownSubjects = knownExceptions.Select(e => e.Subject).ToHashSet(StringComparer.OrdinalIgnoreCase);\r\n  158:         var unlisted = failureSubjects.Except(knownSubjects).ToList();\r\n  159:         var extraKnown = knownSubjects.Except(failureSubjects).ToList();\r\n  160:         if (unlisted.Count > 0 || extraKnown.Count > 0)\r\n  161:         {\r\n  162:             Console.Error.WriteLine(new JsonObject\r\n  163:             {\r\n  164:                 [\"error\"] = \"knownExceptions가 실제 failure와 정확히 일치하지 않음 — 선언 거부\",\r\n  165:                 [\"code\"] = unlisted.Count > 0 ? \"unlisted-reconciliation-failure\" : \"extra-known-exceptions\",\r\n  166:                 [\"unlistedSubjects\"] = new JsonArray(unlisted.Select(s => (JsonNode?)s).ToArray()),\r\n  167:                 [\"extraKnownSubjects\"] = new JsonArray(extraKnown.Select(s => (JsonNode?)s).ToArray()),\r\n  168:             }.ToJsonString());\r\n  169:             return (null, 1);\r\n  170:         }\r\n  171:         return (reconResult, null);\r\n  172:     }\r\n  173: \r\n  174:     // 선행조건 1·3·4·9·10을 검사한다. production 경로(precon=null)에서는 실제 확인을 수행한다. 미충족 시 exit code 반환.\r\n  175:     private static int? CheckAllPreconditions(string root, PreconOverride? precon)\r\n  176:     {\r\n  177:         // 선행조건 1: production에서 실제 dotnet build 실행. 기본값 true 금지.\r\n  178:         var buildOk = precon?.BuildVerified ?? CheckBuildProduction(root);\r\n  179:         if (!buildOk)\r\n  180:             { WriteError(\"선행조건 1 미충족 — clean build exit 0 필요 (dotnet build server -c Release -nologo)\"); return 1; }\r\n  181:         var filesTracked = precon?.FilesTracked ?? CheckFilesTracked(root);\r\n  182:         if (!filesTracked)\r\n  183:             { WriteError(\"선행조건 3 미충족 — StateApplierCli.cs 또는 HandoffIntegrityChecker.cs가 git-tracked 상태가 아님\"); return 1; }\r\n  184:         var noDirectMod = precon?.NoDirectMod ?? CheckNoDirectMod(root);\r\n  185:         if (!noDirectMod)\r\n  186:             { WriteError(\"선행조건 4 미충족 — WORKSTATE.json 또는 applier-log.jsonl가 working tree에서 직접 수정됨\"); return 1; }\r\n  187:         // 선행조건 9: production에서 .claude/settings*.json hooks 확인. 기본값 true 금지.\r\n  188:         var autoOff = precon?.AutoLauncherOff ?? CheckAutoLauncherOff(root);\r\n  189:         if (!autoOff)\r\n  190:             { WriteError(\"선행조건 9 미충족 — 자동 launcher hooks 발견 또는 확인 불가\"); return 1; }\r\n  191:         // 선행조건 10: production에서 state-transition PHASE_CHANGE가 trusted-human-receipt-required로 거부되는지 확인. 기본값 true 금지.\r\n  192:         var highRiskClosed = precon?.HighRiskClosed ?? CheckHighRiskClosed(root);\r\n  193:         if (!highRiskClosed)\r\n  194:             { WriteError(\"선행조건 10 미충족 — high-risk transition(PHASE_CHANGE/RECOVERY/REPLAY)이 fail-closed 되지 않음 또는 확인 불가\"); return 1; }\r\n  195:         return null;\r\n  196:     }\r\n  197: \r\n  198:     // 선행조건 1: dotnet build server -c Release -nologo 실행 후 exit 0 여부를 반환한다.\r\n  199:     private static bool CheckBuildProduction(string root)\r\n  200:     {\r\n  201:         try\r\n  202:         {\r\n  203:             using var p = new Process();\r\n  204:             p.StartInfo = new ProcessStartInfo(\"dotnet\", \"build server -c Release -nologo\")\r\n  205:             {\r\n  206:                 WorkingDirectory = root,\r\n  207:                 RedirectStandardOutput = true,\r\n  208:                 RedirectStandardError = true,\r\n  209:                 UseShellExecute = false,\r\n  210:             };\r\n  211:             p.Start();\r\n  212:             p.StandardOutput.ReadToEnd();\r\n  213:             p.StandardError.ReadToEnd();\r\n  214:             p.WaitForExit(120_000);\r\n  215:             return p.ExitCode == 0;\r\n  216:         }\r\n  217:         catch { return false; }\r\n  218:     }\r\n  219: \r\n  220:     // 선행조건 9: .claude/settings*.json에서 hooks 항목 유무로 자동 launcher 비활성을 판단한다.\r\n  221:     private static bool CheckAutoLauncherOff(string root)\r\n  222:     {\r\n  223:         foreach (var path in GetClaudeSettingsPaths(root))\r\n  224:         {\r\n  225:             if (!File.Exists(path)) continue;\r\n  226:             try\r\n  227:             {\r\n  228:                 var node = JsonNode.Parse(File.ReadAllText(path, new System.Text.UTF8Encoding(false)));\r\n  229:                 if (node?[\"hooks\"] is JsonObject hooks && hooks.Count > 0) return false;\r\n  230:             }\r\n  231:             catch { /* 파싱 불가 — 이 파일은 skip */ }\r\n  232:         }\r\n  233:         return true;\r\n  234:     }\r\n  235: \r\n  236:     // 선행조건 9 보조: 검사 대상 Claude settings 경로 목록.\r\n  237:     private static System.Collections.Generic.IEnumerable<string> GetClaudeSettingsPaths(string root)\r\n  238:     {\r\n  239:         yield return Path.Combine(root, \".claude\", \"settings.json\");\r\n  240:         yield return Path.Combine(root, \".claude\", \"settings.local.json\");\r\n  241:         var home = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);\r\n  242:         if (!string.IsNullOrEmpty(home))\r\n  243:         {\r\n  244:             yield return Path.Combine(home, \".claude\", \"settings.json\");\r\n  245:             yield return Path.Combine(home, \".claude\", \"settings.local.json\");\r\n  246:         }\r\n  247:     }\r\n  248: \r\n  249:     // 선행조건 10: PHASE_CHANGE 전이가 trusted-human-receipt-required로 거부되는지 in-process fixture로 확인한다.\r\n  250:     private static bool CheckHighRiskClosed(string root)\r\n  251:     {\r\n  252:         var tmpEnv = Path.Combine(Path.GetTempPath(), $\"to-hr-check-{Guid.NewGuid():N}.json\");\r\n  253:         try\r\n  254:         {\r\n  255:             File.WriteAllText(tmpEnv,\r\n  256:                 \"{\\\"schemaVersion\\\":1,\\\"transitionKind\\\":\\\"PHASE_CHANGE\\\",\\\"transitionId\\\":\\\"trust-origin-high-risk-check\\\"}\",\r\n  257:                 new System.Text.UTF8Encoding(false));\r\n  258:             var origErr = Console.Error;\r\n  259:             Console.SetError(System.IO.TextWriter.Null);\r\n  260:             int exit;\r\n  261:             try { exit = StateApplierCli.Run([\"state-transition\", \"apply\", \"--envelope\", tmpEnv]); }\r\n  262:             finally { Console.SetError(origErr); }\r\n  263:             return exit == 1; // trusted-human-receipt-required → exit 1\r\n  264:         }\r\n  265:         catch { return false; }\r\n  266:         finally\r\n  267:         {\r\n  268:             try { if (File.Exists(tmpEnv)) File.Delete(tmpEnv); } catch { }\r\n  269:         }\r\n  270:     }\r\n  271: \r\n  272:     // 선행조건 7: baseline commit hash를 반환한다. 시험은 TestPrecon, production은 git.\r\n  273:     private static (string? commit, int? exitCode) GetBaselineCommit(string root, PreconOverride? precon)\r\n  274:     {\r\n  275:         if (precon is not null) return (precon.CommitHash, null);\r\n  276:         try { return (RunGitOutput(root, \"rev-parse HEAD\").Trim(), null); }\r\n  277:         catch (Exception ex) { WriteError($\"git rev-parse HEAD 실패: {ex.Message}\"); return (null, 2); }\r\n  278:     }\r\n  279: \r\n  280:     // record를 구성하고 고정 경로에 atomic-create로 쓴다.\r\n  281:     private static int BuildAndWriteRecord(\r\n  282:         string recordPath, string baselineCommit, string workstateSha256, string applierLogSha256,\r\n  283:         ReconciliationResult reconResult, List<KnownException> knownExceptions)\r\n  284:     {\r\n  285:         var reconVerdict = reconResult.Failures.Count == 0\r\n  286:             ? \"VERIFIED_PASS\" : \"VERIFIED_PASS_WITH_KNOWN_EXCEPTIONS\";\r\n  287:         // declarationCommit 필드 미포함 — 자기참조 방지. annotated tag로 연결.\r\n  288:         var record = new JsonObject\r\n  289:         {\r\n  290:             [\"schemaVersion\"] = 1, [\"trustOriginId\"] = \"TO-2026-001\", [\"trustEpoch\"] = 1,\r\n  291:             [\"declarationType\"] = \"BOOTSTRAP_TRUST_ORIGIN\", [\"baselineCommit\"] = baselineCommit,\r\n  292:             [\"workstateSha256\"] = workstateSha256, [\"applierLogSha256\"] = applierLogSha256,\r\n  293:             [\"stateApplierSchemaVersion\"] = 2, [\"reconciliationSchemaVersion\"] = 2,\r\n  294:             [\"legacyHistory\"] = \"NOT_EXACTLY_REPLAY_VERIFIED\",\r\n  295:             [\"buildVerdict\"] = \"VERIFIED_PASS\", [\"reconciliationVerdict\"] = reconVerdict,\r\n  296:             [\"knownExceptions\"] = BuildExceptionsArray(knownExceptions),\r\n  297:             [\"normalTransitionReady\"] = true, [\"verifiedHumanApprovalReady\"] = false,\r\n  298:             [\"recoveryApplyReady\"] = false, [\"automatedExecutionReady\"] = false,\r\n  299:             [\"phaseChangeReady\"] = false, [\"replayReady\"] = false,\r\n  300:             [\"declaredBy\"] = new JsonObject\r\n  301:             {\r\n  302:                 [\"actorType\"] = \"human\", [\"actorId\"] = \"bootstrap-operator\",\r\n  303:                 [\"actorPath\"] = \"local-manual\",\r\n  304:             },\r\n  305:             [\"declarationStatus\"] = \"HUMAN_DECLARED_NOT_CRYPTOGRAPHICALLY_VERIFIED\",\r\n  306:             [\"declaredAt\"] = DateTime.UtcNow.ToString(\"o\"),\r\n  307:         };\r\n  308:         Directory.CreateDirectory(Path.GetDirectoryName(recordPath)!);\r\n  309:         try\r\n  310:         {\r\n  311:             using var fs = new FileStream(recordPath, FileMode.CreateNew, FileAccess.Write, FileShare.None);\r\n  312:             fs.Write(Encoding.UTF8.GetBytes(record.ToJsonString(WriteOptions)));\r\n  313:         }\r\n  314:         catch (IOException ex) { WriteError($\"record atomic-create 실패 — 이미 존재하거나 쓰기 불가: {ex.Message}\"); return 1; }\r\n  315: \r\n  316:         Console.WriteLine(new JsonObject\r\n  317:         {\r\n  318:             [\"ok\"] = true, [\"trustOriginId\"] = \"TO-2026-001\", [\"trustEpoch\"] = 1,\r\n  319:             [\"baselineCommit\"] = baselineCommit, [\"workstateSha256\"] = workstateSha256,\r\n  320:             [\"applierLogSha256\"] = applierLogSha256, [\"recordPath\"] = recordPath,\r\n  321:             [\"reconciliationVerdict\"] = reconVerdict,\r\n  322:             [\"note\"] = \"선언 완료. 다음: git commit -m '[trust-origin] bootstrap TO-2026-001' → git tag trust-origin/TO-2026-001 <commitHash>\",\r\n  323:         }.ToJsonString(WriteOptions));\r\n  324:         return 0;\r\n  325:     }\r\n  326: \r\n  327:     // --self-test: $TEMP 사본에서 5개 case를 in-process로 검증한다.\r\n  328:     private static int RunSelfTest()\r\n  329:     {\r\n  330:         var tmpBase = Path.Combine(Path.GetTempPath(), $\"to-selftest-{Guid.NewGuid():N}\");\r\n  331:         try { return RunSelfTestInDir(tmpBase); }\r\n  332:         finally\r\n  333:         {\r\n  334:             try { if (Directory.Exists(tmpBase)) Directory.Delete(tmpBase, recursive: true); } catch { }\r\n  335:             NonInteractiveOverride = false;\r\n  336:             TestPrecon = null;\r\n  337:         }\r\n  338:     }\r\n  339: \r\n  340:     // 임시 디렉토리에서 9개 case를 순서대로 실행하고 결과를 보고한다.\r\n  341:     private static int RunSelfTestInDir(string tmpRoot)\r\n  342:     {\r\n  343:         var wsDir = Path.Combine(tmpRoot, \"docs\", \"handoff\");\r\n  344:         var trustDir = Path.Combine(tmpRoot, \"docs\", \"handoff\", \"trust-origin\");\r\n  345:         Directory.CreateDirectory(wsDir);\r\n  346:         Directory.CreateDirectory(trustDir);\r\n  347:         Directory.CreateDirectory(Path.Combine(tmpRoot, \".git\")); // FindRepoRoot 기준점\r\n  348:         var wsPath = Path.Combine(wsDir, \"WORKSTATE.json\");\r\n  349:         var logPath = Path.Combine(wsDir, \"WORKSTATE.applier-log.jsonl\");\r\n  350:         var recordPath = Path.Combine(trustDir, \"TO-2026-001.json\");\r\n  351: \r\n  352:         // knownExceptions에 명시된 오염 — LISTED-TRANSITION이 state에 있고 log에 없음 (declare-ok용)\r\n  353:         const string WsDirty = \"{\\\"schemaVersion\\\":1,\\\"diId\\\":\\\"DI-00-04\\\",\\\"status\\\":\\\"in_progress\\\",\"\r\n  354:             + \"\\\"blockers\\\":[],\\\"nextActions\\\":[\\\"test\\\"],\\\"phaseId\\\":\\\"P00\\\",\\\"wpId\\\":\\\"WP-00\\\",\"\r\n  355:             + \"\\\"updatedAt\\\":\\\"2026-07-14\\\",\\\"updatedBy\\\":\\\"self-test\\\",\"\r\n  356:             + \"\\\"appliedTransitions\\\":[{\\\"id\\\":\\\"LISTED-TRANSITION\\\",\\\"appliedAt\\\":\\\"2026-07-14T00:00:00Z\\\"}]}\";\r\n  357:         // 깨끗한 WORKSTATE — appliedTransitions 없음 → reconciliation PASS\r\n  358:         const string WsClean = \"{\\\"schemaVersion\\\":1,\\\"diId\\\":\\\"DI-00-04\\\",\\\"status\\\":\\\"in_progress\\\",\"\r\n  359:             + \"\\\"blockers\\\":[],\\\"nextActions\\\":[\\\"test\\\"],\\\"phaseId\\\":\\\"P00\\\",\\\"wpId\\\":\\\"WP-00\\\",\"\r\n  360:             + \"\\\"updatedAt\\\":\\\"2026-07-14\\\",\\\"updatedBy\\\":\\\"self-test\\\",\\\"appliedTransitions\\\":[]}\";\r\n  361:         // 미명시 오염 — UNLISTED-TRANSITION이 state·log·knownExceptions 어디에도 없음 (unlisted-failure용)\r\n  362:         const string WsUnlisted = \"{\\\"schemaVersion\\\":1,\\\"diId\\\":\\\"DI-00-04\\\",\\\"status\\\":\\\"in_progress\\\",\"\r\n  363:             + \"\\\"blockers\\\":[],\\\"nextActions\\\":[\\\"test\\\"],\\\"phaseId\\\":\\\"P00\\\",\\\"wpId\\\":\\\"WP-00\\\",\"\r\n  364:             + \"\\\"updatedAt\\\":\\\"2026-07-14\\\",\\\"updatedBy\\\":\\\"self-test\\\",\"\r\n  365:             + \"\\\"appliedTransitions\\\":[{\\\"id\\\":\\\"UNLISTED-TRANSITION\\\",\\\"appliedAt\\\":\\\"2026-07-14T00:00:00Z\\\"}]}\";\r\n  366: \r\n  367:         var goodPrecon = new PreconOverride(true, true, true, \"abc123def456abc123def456abc123def456abc1\", true, true);\r\n  368:         var mismatches = new JsonArray();\r\n  369:         var caseResults = new JsonArray();\r\n  370:         // 실행 순서: declare-ok → no-self-reference → extra-known-exception → unlisted-failure → redeclare → record-path-fixed → record-ready-flags-complete → build-verdict-not-forged → production-preconditions-not-default-true\r\n  371:         RunCaseDeclareOk(tmpRoot, wsPath, logPath, recordPath, WsDirty, goodPrecon, caseResults, mismatches);\r\n  372:         RunCaseNoSelfReference(recordPath, caseResults, mismatches);\r\n  373:         RunCaseExtraKnownException(tmpRoot, wsPath, logPath, recordPath, WsDirty, goodPrecon, caseResults, mismatches);\r\n  374:         RunCaseUnlistedFailure(tmpRoot, wsPath, logPath, recordPath, WsUnlisted, goodPrecon, caseResults, mismatches);\r\n  375:         RunCaseRedeclare(tmpRoot, wsPath, logPath, recordPath, WsClean, goodPrecon, caseResults, mismatches);\r\n  376:         RunCaseRecordPathFixed(tmpRoot, wsPath, logPath, recordPath, WsClean, goodPrecon, caseResults, mismatches);\r\n  377:         RunCaseRecordReadyFlagsComplete(recordPath, caseResults, mismatches);\r\n  378:         RunCaseBuildVerdictNotForged(tmpRoot, wsPath, logPath, recordPath, WsClean, goodPrecon, caseResults, mismatches);\r\n  379:         RunCaseProductionPreconNotDefaultTrue(tmpRoot, wsPath, logPath, recordPath, WsClean, caseResults, mismatches);\r\n  380:         NonInteractiveOverride = false; TestPrecon = null;\r\n  381:         if (mismatches.Count == 0)\r\n  382:         {\r\n  383:             Console.WriteLine(new JsonObject { [\"selfTest\"] = \"trust-origin\", [\"verdict\"] = \"PASS\",\r\n  384:                 [\"casesRun\"] = caseResults.Count, [\"cases\"] = caseResults,\r\n  385:                 [\"selfFalsificationNote\"] = \"기대값을 틀리게 적으면 mismatches > 0 → exit 1. 판정선 4: 기대 epoch를 2로 바꿔 FAIL 실증.\",\r\n  386:             }.ToJsonString(WriteOptions));\r\n  387:             return 0;\r\n  388:         }\r\n  389:         Console.Error.WriteLine(new JsonObject { [\"selfTest\"] = \"trust-origin\", [\"verdict\"] = \"FAIL\",\r\n  390:             [\"mismatchCount\"] = mismatches.Count, [\"mismatches\"] = mismatches, [\"cases\"] = caseResults,\r\n  391:         }.ToJsonString(WriteOptions));\r\n  392:         return 1;\r\n  393:     }\r\n  394: \r\n  395:     // case: declare-ok — failure가 knownExceptions에 명시돼 있으면 record 생성, trustEpoch=1.\r\n  396:     private static void RunCaseDeclareOk(\r\n  397:         string tmpRoot, string wsPath, string logPath, string recordPath,\r\n  398:         string wsDirty, PreconOverride precon, JsonArray caseResults, JsonArray mismatches)\r\n  399:     {\r\n  400:         ResetFixture(wsPath, wsDirty, logPath, recordPath);\r\n  401:         NonInteractiveOverride = true; TestPrecon = precon;\r\n  402:         var exceptions = new List<KnownException>\r\n  403:         {\r\n  404:             new(\"state-transition-not-logged\", \"LISTED-TRANSITION\",\r\n  405:                 \"자기 시험용 fixture — state에 있지만 log에 없는 전이\", \"self-test fixture\", \"self-test only\"),\r\n  406:         };\r\n  407:         var exit = RunDeclareCore(tmpRoot, exceptions);\r\n  408:         var recExists = File.Exists(recordPath);\r\n  409:         var epoch = 0; string? commit = null; var hasDC = false; string? verdict = null;\r\n  410:         if (recExists)\r\n  411:         {\r\n  412:             var rec = JsonNode.Parse(File.ReadAllText(recordPath))?.AsObject();\r\n  413:             epoch = rec?[\"trustEpoch\"]?.GetValue<int>() ?? 0;\r\n  414:             commit = rec?[\"baselineCommit\"]?.GetValue<string>();\r\n  415:             hasDC = rec?.ContainsKey(\"declarationCommit\") ?? false;\r\n  416:             verdict = rec?[\"reconciliationVerdict\"]?.GetValue<string>();\r\n  417:         }\r\n  418:         var ok = exit == 0 && recExists && epoch == 1 && commit == precon.CommitHash\r\n  419:             && !hasDC && verdict == \"VERIFIED_PASS_WITH_KNOWN_EXCEPTIONS\";\r\n  420:         caseResults.Add(new JsonObject { [\"case\"] = \"declare-ok\", [\"exit\"] = exit, [\"recordExists\"] = recExists,\r\n  421:             [\"trustEpoch\"] = epoch, [\"commitMatch\"] = (commit == precon.CommitHash),\r\n  422:             [\"noDeclarationCommit\"] = !hasDC, [\"reconciliationVerdict\"] = verdict, [\"pass\"] = ok });\r\n  423:         if (!ok) mismatches.Add(new JsonObject { [\"case\"] = \"declare-ok\",\r\n  424:             [\"expected\"] = \"exit=0, record, epoch=1, commitMatch, no-DC, verdict=VERIFIED_PASS_WITH_KNOWN_EXCEPTIONS\",\r\n  425:             [\"actual\"] = $\"exit={exit},exists={recExists},epoch={epoch},commit={commit},hasDC={hasDC},verdict={verdict}\" });\r\n  426:     }\r\n  427: \r\n  428:     // case: no-self-reference — declare-ok가 생성한 record에 declarationCommit 필드가 없다.\r\n  429:     private static void RunCaseNoSelfReference(string recordPath, JsonArray caseResults, JsonArray mismatches)\r\n  430:     {\r\n  431:         var recExists = File.Exists(recordPath);\r\n  432:         var hasDC = false;\r\n  433:         if (recExists)\r\n  434:         {\r\n  435:             try { var rec = JsonNode.Parse(File.ReadAllText(recordPath))?.AsObject(); hasDC = rec?.ContainsKey(\"declarationCommit\") ?? false; }\r\n  436:             catch { hasDC = true; }\r\n  437:         }\r\n  438:         var ok = recExists && !hasDC;\r\n  439:         caseResults.Add(new JsonObject { [\"case\"] = \"no-self-reference\", [\"recordExists\"] = recExists, [\"hasDeclarationCommit\"] = hasDC, [\"pass\"] = ok });\r\n  440:         if (!ok) mismatches.Add(new JsonObject { [\"case\"] = \"no-self-reference\",\r\n  441:             [\"expected\"] = \"record exists, declarationCommit 없음\", [\"actual\"] = $\"recExists={recExists},hasDC={hasDC}\" });\r\n  442:     }\r\n  443: \r\n  444:     // case: unlisted-failure — reconciliation failure가 knownExceptions에 없으면 선언 거부.\r\n  445:     private static void RunCaseUnlistedFailure(\r\n  446:         string tmpRoot, string wsPath, string logPath, string recordPath,\r\n  447:         string wsUnlisted, PreconOverride precon, JsonArray caseResults, JsonArray mismatches)\r\n  448:     {\r\n  449:         ResetFixture(wsPath, wsUnlisted, logPath, recordPath);\r\n  450:         NonInteractiveOverride = true; TestPrecon = precon;\r\n  451:         var exit = RunDeclareCore(tmpRoot, []); // knownExceptions 비어 있음 → UNLISTED-TRANSITION 미명시 → 거부\r\n  452:         var recCreated = File.Exists(recordPath);\r\n  453:         var ok = exit == 1 && !recCreated;\r\n  454:         caseResults.Add(new JsonObject { [\"case\"] = \"unlisted-failure\", [\"exit\"] = exit, [\"recordCreated\"] = recCreated, [\"pass\"] = ok });\r\n  455:         if (!ok) mismatches.Add(new JsonObject { [\"case\"] = \"unlisted-failure\",\r\n  456:             [\"expected\"] = \"exit=1 (선언 거부), record 미생성\", [\"actual\"] = $\"exit={exit},recordCreated={recCreated}\" });\r\n  457:     }\r\n  458: \r\n  459:     // case: redeclare — trustEpoch >= 1 이미 존재하면 거부.\r\n  460:     private static void RunCaseRedeclare(\r\n  461:         string tmpRoot, string wsPath, string logPath, string recordPath,\r\n  462:         string wsClean, PreconOverride precon, JsonArray caseResults, JsonArray mismatches)\r\n  463:     {\r\n  464:         ResetFixture(wsPath, wsClean, logPath, recordPath);\r\n  465:         Directory.CreateDirectory(Path.GetDirectoryName(recordPath)!);\r\n  466:         File.WriteAllText(recordPath, \"{\\\"schemaVersion\\\":1,\\\"trustOriginId\\\":\\\"TO-2026-001\\\",\\\"trustEpoch\\\":1}\", new UTF8Encoding(false));\r\n  467:         NonInteractiveOverride = true; TestPrecon = precon;\r\n  468:         var exit = RunDeclareCore(tmpRoot, []);\r\n  469:         var ok = exit == 1;\r\n  470:         caseResults.Add(new JsonObject { [\"case\"] = \"redeclare\", [\"exit\"] = exit, [\"pass\"] = ok });\r\n  471:         if (!ok) mismatches.Add(new JsonObject { [\"case\"] = \"redeclare\",\r\n  472:             [\"expected\"] = \"exit=1 (재선언 거부)\", [\"actual\"] = $\"exit={exit}\" });\r\n  473:     }\r\n  474: \r\n  475:     // case: record-path-fixed — 선언은 canonical record 경로 외 다른 파일을 쓰지 않는다.\r\n  476:     private static void RunCaseRecordPathFixed(\r\n  477:         string tmpRoot, string wsPath, string logPath, string recordPath,\r\n  478:         string wsClean, PreconOverride precon, JsonArray caseResults, JsonArray mismatches)\r\n  479:     {\r\n  480:         ResetFixture(wsPath, wsClean, logPath, recordPath);\r\n  481:         NonInteractiveOverride = true; TestPrecon = precon;\r\n  482:         var beforeFiles = Directory.GetFiles(tmpRoot, \"*\", SearchOption.AllDirectories)\r\n  483:             .Select(Path.GetFullPath).ToHashSet(StringComparer.OrdinalIgnoreCase);\r\n  484:         var exit = RunDeclareCore(tmpRoot, []);\r\n  485:         var afterFiles = Directory.GetFiles(tmpRoot, \"*\", SearchOption.AllDirectories)\r\n  486:             .Select(Path.GetFullPath).ToHashSet(StringComparer.OrdinalIgnoreCase);\r\n  487:         var newFiles = afterFiles.Except(beforeFiles).ToList();\r\n  488:         var canonicalPath = Path.GetFullPath(recordPath);\r\n  489:         var onlyCanonical = exit == 0 && newFiles.Count == 1 &&\r\n  490:             string.Equals(newFiles[0], canonicalPath, StringComparison.OrdinalIgnoreCase);\r\n  491:         caseResults.Add(new JsonObject { [\"case\"] = \"record-path-fixed\", [\"exit\"] = exit,\r\n  492:             [\"newFileCount\"] = newFiles.Count, [\"onlyCanonicalPath\"] = onlyCanonical, [\"pass\"] = onlyCanonical });\r\n  493:         if (!onlyCanonical) mismatches.Add(new JsonObject { [\"case\"] = \"record-path-fixed\",\r\n  494:             [\"expected\"] = \"exit=0, 신규 파일 1개만 (canonical path)\",\r\n  495:             [\"actual\"] = $\"exit={exit},newFiles=[{string.Join(\";\", newFiles)}]\" });\r\n  496:     }\r\n  497: \r\n  498:     // case: extra-known-exception — knownExceptions가 실제 failure보다 많으면 선언 거부.\r\n  499:     private static void RunCaseExtraKnownException(\r\n  500:         string tmpRoot, string wsPath, string logPath, string recordPath,\r\n  501:         string wsDirty, PreconOverride precon, JsonArray caseResults, JsonArray mismatches)\r\n  502:     {\r\n  503:         ResetFixture(wsPath, wsDirty, logPath, recordPath);\r\n  504:         NonInteractiveOverride = true; TestPrecon = precon;\r\n  505:         var exceptions = new List<KnownException>\r\n  506:         {\r\n  507:             new(\"state-transition-not-logged\", \"LISTED-TRANSITION\", \"fixture 알려진 오염\", \"fixture\", \"fixture\"),\r\n  508:             new(\"extra-never-observed\", \"FAKE-NEVER-OBSERVED\", \"실제 failure 없는 가짜 예외 — extra\", \"fixture\", \"fixture\"),\r\n  509:         };\r\n  510:         var exit = RunDeclareCore(tmpRoot, exceptions);\r\n  511:         var recCreated = File.Exists(recordPath);\r\n  512:         var ok = exit == 1 && !recCreated;\r\n  513:         caseResults.Add(new JsonObject { [\"case\"] = \"extra-known-exception\", [\"exit\"] = exit,\r\n  514:             [\"recordCreated\"] = recCreated, [\"pass\"] = ok });\r\n  515:         if (!ok) mismatches.Add(new JsonObject { [\"case\"] = \"extra-known-exception\",\r\n  516:             [\"expected\"] = \"exit=1 (extra known exception 거부), record 미생성\",\r\n  517:             [\"actual\"] = $\"exit={exit},recordCreated={recCreated}\" });\r\n  518:     }\r\n  519: \r\n  520:     // case: record-ready-flags-complete — record에 phaseChangeReady:false, replayReady:false 존재.\r\n  521:     private static void RunCaseRecordReadyFlagsComplete(string recordPath, JsonArray caseResults, JsonArray mismatches)\r\n  522:     {\r\n  523:         var recExists = File.Exists(recordPath);\r\n  524:         bool hasPCR = false, hasRR = false, pcrFalse = false, rrFalse = false;\r\n  525:         if (recExists)\r\n  526:         {\r\n  527:             try\r\n  528:             {\r\n  529:                 var rec = JsonNode.Parse(File.ReadAllText(recordPath))?.AsObject();\r\n  530:                 hasPCR = rec?.ContainsKey(\"phaseChangeReady\") ?? false;\r\n  531:                 hasRR = rec?.ContainsKey(\"replayReady\") ?? false;\r\n  532:                 pcrFalse = rec?[\"phaseChangeReady\"]?.GetValue<bool>() == false;\r\n  533:                 rrFalse = rec?[\"replayReady\"]?.GetValue<bool>() == false;\r\n  534:             }\r\n  535:             catch { }\r\n  536:         }\r\n  537:         var ok = recExists && hasPCR && hasRR && pcrFalse && rrFalse;\r\n  538:         caseResults.Add(new JsonObject { [\"case\"] = \"record-ready-flags-complete\",\r\n  539:             [\"recordExists\"] = recExists, [\"hasPhaseChangeReady\"] = hasPCR, [\"hasReplayReady\"] = hasRR,\r\n  540:             [\"phaseChangeFalse\"] = pcrFalse, [\"replayFalse\"] = rrFalse, [\"pass\"] = ok });\r\n  541:         if (!ok) mismatches.Add(new JsonObject { [\"case\"] = \"record-ready-flags-complete\",\r\n  542:             [\"expected\"] = \"record에 phaseChangeReady:false, replayReady:false 존재\",\r\n  543:             [\"actual\"] = $\"exists={recExists},hasPCR={hasPCR},hasRR={hasRR},pcrFalse={pcrFalse},rrFalse={rrFalse}\" });\r\n  544:     }\r\n  545: \r\n  546:     // case: build-verdict-not-forged — BuildVerified=false이면 exit 1, record 미생성.\r\n  547:     private static void RunCaseBuildVerdictNotForged(\r\n  548:         string tmpRoot, string wsPath, string logPath, string recordPath,\r\n  549:         string wsClean, PreconOverride precon, JsonArray caseResults, JsonArray mismatches)\r\n  550:     {\r\n  551:         var badPrecon = precon with { BuildVerified = false };\r\n  552:         ResetFixture(wsPath, wsClean, logPath, recordPath);\r\n  553:         NonInteractiveOverride = true; TestPrecon = badPrecon;\r\n  554:         var exit = RunDeclareCore(tmpRoot, []);\r\n  555:         var recCreated = File.Exists(recordPath);\r\n  556:         var ok = exit == 1 && !recCreated;\r\n  557:         caseResults.Add(new JsonObject { [\"case\"] = \"build-verdict-not-forged\", [\"exit\"] = exit,\r\n  558:             [\"recordCreated\"] = recCreated, [\"pass\"] = ok,\r\n  559:             [\"note\"] = \"BuildVerified=false → 선언 거부 → VERIFIED_PASS record 생성 불가\" });\r\n  560:         if (!ok) mismatches.Add(new JsonObject { [\"case\"] = \"build-verdict-not-forged\",\r\n  561:             [\"expected\"] = \"exit=1, record 미생성 (build 미확인 경로는 VERIFIED_PASS 기록 불가)\",\r\n  562:             [\"actual\"] = $\"exit={exit},recordCreated={recCreated}\" });\r\n  563:     }\r\n  564: \r\n  565:     // case: production-preconditions-not-default-true — TestPrecon=null 시 production path가 기본 true로 통과하지 못함.\r\n  566:     private static void RunCaseProductionPreconNotDefaultTrue(\r\n  567:         string tmpRoot, string wsPath, string logPath, string recordPath,\r\n  568:         string wsClean, JsonArray caseResults, JsonArray mismatches)\r\n  569:     {\r\n  570:         ResetFixture(wsPath, wsClean, logPath, recordPath);\r\n  571:         NonInteractiveOverride = true; TestPrecon = null; // production 경로 강제\r\n  572:         var exit = RunDeclareCore(tmpRoot, []);\r\n  573:         var recCreated = File.Exists(recordPath);\r\n  574:         // tmpRoot에는 dotnet 프로젝트 없음 → CheckBuildProduction 실패 → exit != 0\r\n  575:         var ok = exit != 0 && !recCreated;\r\n  576:         caseResults.Add(