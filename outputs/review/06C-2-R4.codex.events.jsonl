rdict-not-forged\", [\"exit\"] = exit,\r\n  605:             [\"recordCreated\"] = recCreated, [\"pass\"] = ok,\r\n  606:             [\"note\"] = \"BuildVerified=false → 선언 거부 → VERIFIED_PASS record 생성 불가\" });\r\n  607:         if (!ok) mismatches.Add(new JsonObject { [\"case\"] = \"build-verdict-not-forged\",\r\n  608:             [\"expected\"] = \"exit=1, record 미생성 (build 미확인 경로는 VERIFIED_PASS 기록 불가)\",\r\n  609:             [\"actual\"] = $\"exit={exit},recordCreated={recCreated}\" });\r\n  610:     }\r\n  611: \r\n  612:     // case: production-preconditions-not-default-true — TestPrecon=null 시 production path가 기본 true로 통과하지 못함.\r\n  613:     private static void RunCaseProductionPreconNotDefaultTrue(\r\n  614:         string tmpRoot, string wsPath, string logPath, string recordPath,\r\n  615:         string wsClean, JsonArray caseResults, JsonArray mismatches)\r\n  616:     {\r\n  617:         ResetFixture(wsPath, wsClean, logPath, recordPath);\r\n  618:         NonInteractiveOverride = true; TestPrecon = null; // production 경로 강제\r\n  619:         var exit = RunDeclareCore(tmpRoot, []);\r\n  620:         var recCreated = File.Exists(recordPath);\r\n  621:         // tmpRoot에는 dotnet 프로젝트 없음 → CheckBuildProduction 실패 → exit != 0\r\n  622:         var ok = exit != 0 && !recCreated;\r\n  623:         caseResults.Add(new JsonObject { [\"case\"] = \"production-preconditions-not-default-true\",\r\n  624:             [\"exit\"] = exit, [\"recordCreated\"] = recCreated, [\"pass\"] = ok,\r\n  625:             [\"note\"] = \"TestPrecon=null: production path에서 build check 실행 — tmpRoot에 dotnet 프로젝트 없어 실패\" });\r\n  626:         if (!ok) mismatches.Add(new JsonObject { [\"case\"] = \"production-preconditions-not-default-true\",\r\n  627:             [\"expected\"] = \"exit!=0 (production precondition 실패), record 미생성\",\r\n  628:             [\"actual\"] = $\"exit={exit},recordCreated={recCreated}\" });\r\n  629:     }\r\n  630: \r\n  631:     // case: high-risk-full-envelope-<kind> — full envelope로 고위험 전이를 apply → exit 1, trusted-human-receipt-required reason 일치.\r\n  632:     private static void RunCaseHighRiskFullEnvelope(string kind, JsonArray caseResults, JsonArray mismatches)\r\n  633:     {\r\n  634:         var caseName = $\"high-risk-full-envelope-{kind.ToLowerInvariant().Replace('_', '-')}\";\r\n  635:         var (exit, stderrText, reasonMatched) = RunHighRiskEnvelopeCheck(kind);\r\n  636:         var ok = exit == 1 && reasonMatched;\r\n  637:         caseResults.Add(new JsonObject { [\"case\"] = caseName, [\"kind\"] = kind, [\"exit\"] = exit,\r\n  638:             [\"reasonMatched\"] = reasonMatched, [\"pass\"] = ok,\r\n  639:             [\"note\"] = \"full envelope → exit 1, reason 필드 정확 매칭. StateApplierCli.RunApply가 canonical WORKSTATE를 로드하나 high-risk 분기는 request/candidate 읽기 전에 실행된다.\" });\r\n  640:         if (!ok) mismatches.Add(new JsonObject { [\"case\"] = caseName,\r\n  641:             [\"expected\"] = \"exit=1, reasonMatched=true (trusted-human-receipt-required)\",\r\n  642:             [\"actual\"] = $\"exit={exit},reasonMatched={reasonMatched}\" });\r\n  643:     }\r\n  644: \r\n  645:     // case: launcher-settings-malformed — malformed settings.json이 있으면 CheckAutoLauncherOff → false (fail-closed).\r\n  646:     private static void RunCaseLauncherSettingsMalformed(string tmpRoot, JsonArray caseResults, JsonArray mismatches)\r\n  647:     {\r\n  648:         var claudeDir = Path.Combine(tmpRoot, \".claude\");\r\n  649:         Directory.CreateDirectory(claudeDir);\r\n  650:         var settingsPath = Path.Combine(claudeDir, \"settings.json\");\r\n  651:         File.WriteAllText(settingsPath, \"malformed-not-json\", new System.Text.UTF8Encoding(false));\r\n  652:         try\r\n  653:         {\r\n  654:             var result = CheckAutoLauncherOff(tmpRoot);\r\n  655:             var ok = !result; // malformed → fail-closed → false\r\n  656:             caseResults.Add(new JsonObject { [\"case\"] = \"launcher-settings-malformed\",\r\n  657:                 [\"checkAutoLauncherOffResult\"] = result, [\"pass\"] = ok,\r\n  658:                 [\"note\"] = \"malformed settings.json → 확인 불가 → fail-closed(false)\" });\r\n  659:             if (!ok) mismatches.Add(new JsonObject { [\"case\"] = \"launcher-settings-malformed\",\r\n  660:                 [\"expected\"] = \"false (malformed JSON → fail-closed)\", [\"actual\"] = result.ToString() });\r\n  661:         }\r\n  662:         finally\r\n  663:         {\r\n  664:             try { File.Delete(settingsPath); } catch { }\r\n  665:         }\r\n  666:     }\r\n  667: \r\n  668:     // case: launcher-settings-hooks-variant — 다양한 hooks 값 형태로 CheckAutoLauncherOff 반환값을 검증한다.\r\n  669:     private static void RunCaseLauncherSettingsHooksVariant(\r\n  670:         string tmpRoot, string caseName, string settingsJson, bool expectedResult,\r\n  671:         JsonArray caseResults, JsonArray mismatches)\r\n  672:     {\r\n  673:         var claudeDir = Path.Combine(tmpRoot, \".claude\");\r\n  674:         Directory.CreateDirectory(claudeDir);\r\n  675:         var settingsPath = Path.Combine(claudeDir, \"settings.json\");\r\n  676:         File.WriteAllText(settingsPath, settingsJson, new System.Text.UTF8Encoding(false));\r\n  677:         try\r\n  678:         {\r\n  679:             var result = CheckAutoLauncherOff(tmpRoot);\r\n  680:             var ok = result == expectedResult;\r\n  681:             caseResults.Add(new JsonObject { [\"case\"] = caseName, [\"settingsJson\"] = settingsJson,\r\n  682:                 [\"checkAutoLauncherOffResult\"] = result, [\"expectedResult\"] = expectedResult, [\"pass\"] = ok });\r\n  683:             if (!ok) mismatches.Add(new JsonObject { [\"case\"] = caseName,\r\n  684:                 [\"expected\"] = expectedResult.ToString().ToLowerInvariant(),\r\n  685:                 [\"actual\"] = result.ToString().ToLowerInvariant() });\r\n  686:         }\r\n  687:         finally\r\n  688:         {\r\n  689:             try { File.Delete(settingsPath); } catch { }\r\n  690:         }\r\n","exit_code":0,"status":"completed"}}
