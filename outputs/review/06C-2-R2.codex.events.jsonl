\r\\n   92: \\r\\n   93:         foreach (var dir in scanDirs.Where(Directory.Exists))\\r\\n   94:         {\\r\\n   95:             foreach (var file in Directory.EnumerateFiles(dir, \\\"*\\\", SearchOption.AllDirectories))\\r\\n   96:             {\\r\\n   97:                 var ext = Path.GetExtension(file).ToLowerInvariant();\\r\\n   98:                 if (ActiveExtensions.Contains(ext))\\r\\n   99:                     yield return file;\\r\\n  100:             }\\r\\n  101:         }\\r\\n  102: \\r\\n  103:         // 猷⑦듃???ㅽ겕由쏀듃쨌manifest ?뚯씪???ы븿.\\r\\n  104:         foreach (var ext in new[] { \\\"*.ps1\\\", \\\"*.sh\\\", \\\"*.cmd\\\", \\\"*.bat\\\", \\\"*.json\\\", \\\"*.yaml\\\", \\\"*.yml\\\" })\\r\\n  105:         {\\r\\n  106:             foreach (var file in Directory.GetFiles(root, ext))\\r\\n  107:                 yield return file;\\r\\n  108:         }\\r\\n  109:     }\\r\\n  110: \\r\\n  111:     // docs/handoff/CALLSITE-HISTORICAL.json?먯꽌 ??궗??利앷굅 ?뚯씪 紐⑸줉???쎈뒗??\\r\\n  112:     private static HashSet<string> LoadHistoricalFiles(string root)\\r\\n  113:     {\\r\\n  114:         var path = Path.Combine(root, \\\"docs\\\", \\\"handoff\\\", \\\"CALLSITE-HISTORICAL.json\\\");\\r\\n  115:         if (!File.Exists(path)) return [];\\r\\n  116:         try\\r\\n  117:         {\\r\\n  118:             var doc = JsonNode.Parse(File.ReadAllText(path));\\r\\n  119:             var arr = doc?[\\\"historicalFiles\\\"]?.AsArray();\\r\\n  120:             if (arr is null) return [];\\r\\n  121:             return arr.Select(n => n?.GetValue<string>() ?? \\\"\\\")\\r\\n  122:                       .Where(s => s.Length > 0)\\r\\n  123:                       .ToHashSet(StringComparer.OrdinalIgnoreCase);\\r\\n  124:         }\\r\\n  125:         catch { return []; }\\r\\n  126:     }\\r\\n  127: \\r\\n  128:     // 寃쎈줈媛 ??궗??利앷굅 紐낆떆 紐⑸줉???뺥솗???쇱튂?섎뒗吏 ?뺤씤?쒕떎 (?묐몢??留ㅼ묶 湲덉?).\\r\\n  129:     private static bool IsHistorical(string relPath, HashSet<string> historicalFiles)\\r\\n  130:     {\\r\\n  131:         var normalized = relPath.Replace('\\\\\\\\', '/');\\r\\n  132:         return historicalFiles.Contains(normalized);\\r\\n  133:     }\\r\\n  134: \\r\\n  135:     // ?뚯씪 ?댁슜??legacy single-shot ?⑦꽩???덈뒗吏 ?뺤씤?쒕떎.\\r\\n  136:     private static bool ContainsLegacyCall(string filePath)\\r\\n  137:     {\\r\\n  138:         try\\r\\n  139:         {\\r\\n  140:             var content = File.ReadAllText(filePath);\\r\\n  141:             return LegacyCallPattern.IsMatch(content);\\r\\n  142:         }\\r\\n  143:         catch { return false; }\\r\\n  144:     }\\r\\n  145: \\r\\n  146:     // ?덈? 寃쎈줈瑜???μ냼 猷⑦듃 湲곗? ?곷? 寃쎈줈濡?蹂?섑븳??\\r\\n  147:     private static string ToRelative(string absPath, string root)\\r\\n  148:     {\\r\\n  149:         if (absPath.StartsWith(root, StringComparison.OrdinalIgnoreCase))\\r\\n  150:             return absPath[(root.Length + 1)..].Replace('\\\\\\\\', '/');\\r\\n  151:         return absPath.Replace('\\\\\\\\', '/');\\r\\n  152:     }\\r\\n  153: }\\r\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n.\\outputs\\sonnet-06C-2-R1.out.jsonl:1:{\"type\":\"system\",\"subtype\":\"init\",\"cwd\":\"C:\\\\Users\\\\1\\\\Documents\\\\Local-First Workflow Dashboard\",\"session_id\":\"bf83d8ef-27bc-44e2-8490-f5b3cbb35999\",\"tools\":[\"Task\",\"AskUserQuestion\",\"Bash\",\"CronCreate\",\"CronDelete\",\"CronList\",\"Edit\",\"EnterPlanMode\",\"EnterWorktree\",\"ExitPlanMode\",\"ExitWorktree\",\"Glob\",\"Grep\",\"Monitor\",\"NotebookEdit\",\"PowerShell\",\"PushNotification\",\"Read\",\"RemoteTrigger\",\"ScheduleWakeup\",\"Skill\",\"TaskOutput\",\"TaskStop\",\"TodoWrite\",\"ToolSearch\",\"WebFetch\",\"WebSearch\",\"Write\"],\"mcp_servers\":[],\"model\":\"claude-sonnet-4-6\",\"permissionMode\":\"bypassPermissions\",\"slash_commands\":[\"update-config\",\"debug\",\"simplify\",\"batch\",\"fewer-permission-prompts\",\"loop\",\"schedule\",\"claude-api\",\"compact\",\"context\",\"cost\",\"heapdump\",\"ini