4:             [\"preStateSha256\"] = preStateSha256,\r\n  205:             [\"expectedPostStateSha256\"] = postStateSha256,\r\n  206:             [\"transitionContractSha256\"] = contractHash,\r\n  207:         }.ToJsonString(WriteOptions));\r\n  208:         return 0;\r\n  209:     }\r\n  210: \r\n  211:     // apply: 옵션을 검증하고 ApplyEnvelopeCore에 위임한다.\r\n  212:     private static int RunApply(string[] args)\r\n  213:     {\r\n  214:         var optErr = ValidateOptions(ParseFlagMap(args, 2), ApplyKnownKeys);\r\n  215:         if (optErr is not null) { Console.Error.WriteLine($\"{{\\\"error\\\":\\\"{optErr}\\\"}}\"); return 2; }\r\n  216:         var opts = ParseApplyArgs(args);\r\n  217:         if (opts is null)\r\n  218:         {\r\n  219:             Console.Error.WriteLine(\"{\\\"error\\\":\\\"apply에는 --envelope 이 필요합니다\\\"}\");\r\n  220:             return 2;\r\n  221:         }\r\n  222: \r\n  223:         var envelope = ReadEnvelope(opts.EnvelopePath);\r\n  224:         if (envelope is null) return 2;\r\n  225: \r\n  226:         var ctx = LoadWorkstateContextFromRoot(GitTools.FindRepoRoot());\r\n  227:         if (ctx is null) return 2;\r\n  228:         return ApplyEnvelopeCore(ctx.Value, envelope, opts.DryRun);\r\n  229:     }\r\n  230: \r\n  231:     // apply 핵심 — root를 명시적으로 받아 자기 시험과 production 경로 공유.\r\n  232:     private static int ApplyEnvelopeCore(\r\n  233:         (string root, string workstatePath, string logPath, byte[] rawWorkstateBytes, JsonObject workstate, string rawWorkstateStr) ctx,\r\n  234:         EnvelopeData envelope, bool dryRun)\r\n  235:     {\r\n  236:         // unknown transitionKind는 fail-closed — NORMAL/PHASE_CHANGE/RECOVERY/REPLAY 외 거부.\r\n  237:         if (!ValidTransitionKinds.Contains(envelope.TransitionKind))\r\n  238:             return Fail(1, envelope.TransitionId, \"unknown-transition-kind\",\r\n  239:                 $\"transitionKind='{envelope.TransitionKind}'은 알 수 없는 종류입니다 (허용: NORMAL, PHASE_CHANGE, RECOVERY, 