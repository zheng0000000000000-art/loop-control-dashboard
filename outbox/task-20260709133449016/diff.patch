+  if (status === "pending_review") {
+    return "submitted";
+  }
+
+  return status ?? "draft";
+}
+
+// 숫자 변경 항목의 증감률을 계산한다.
+function getValueDeltaPercent(before, after) {
+  if (typeof before !== "number" || typeof after !== "number") {
+    return NaN;
+  }
+
+  if (before === 0) {
+    return after === 0 ? 0 : 100;
+  }
+
+  return Math.abs((after - before) / before) * 100;
