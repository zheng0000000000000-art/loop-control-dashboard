-    id: haltReason?.type === "guardrail" ? "guardrail" : "",
-    canAcknowledge: haltReason?.type === "guardrail",
-    badgeStatus: `loop_${loopState}`,
-    badgeLabel: haltReason?.type === "guardrail" ? t("halt.guardrailBadge") : formatLoopState(loopState),
-    detail:
