-      type: "checkpoint",
-      id: pauseReason.checkpointId ?? workflowState.checkpointId ?? "",
-      canAcknowledge: true,
-      badgeStatus: "loop_paused",
-      badgeLabel: t("halt.checkpointBadge"),
-      detail: t("halt.checkpointDetail", {
