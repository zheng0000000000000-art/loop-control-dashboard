{
  "schemaVersion": 2,
  "stages": [
    {
      "id": "goals",
      "name": "목표 확인",
      "description": "개발 팩이 측정할 기준과 통과 조건을 확인한다."
    },
    {
      "id": "measure",
      "name": "측정",
      "description": "저장소 파일을 규칙 기반으로 스캔해 사실 값을 기록한다."
    },
    {
      "id": "deviationCheck",
      "name": "괴리 판정",
      "description": "측정 결과가 블루프린트 기준 안에 있는지 판정한다."
    },
    {
      "id": "changeReview",
      "name": "변경 검토",
      "description": "자동 생성된 변경 제안을 사람이 검토하고 결정한다.",
      "requiresHuman": true,
      "gate": [
        { "check": "stageStatus", "stage": "deviationCheck", "mustBe": ["passed", "warning"] }
      ]
    },
    {
      "id": "apply",
      "name": "적용",
      "description": "승인된 수정 지시를 바탕으로 사람이 저장소를 고친다."
    }
  ],
  "measurementProvider": {
    "id": "dev-pack-checks",
    "targetPath": "../.."
  },
  "guardrails": {
    "maxLoopIterations": 10,
    "maxEstimatedCost": 5.0,
    "maxSubscriptionCalls": 5
  },
  "reviewPolicy": {
    "autoApprove": { "enabled": false, "maxRisk": "low", "maxAutoApprovalsPerLoop": 3 },
    "riskRules": [
      { "if": "changeCount <= 3 && maxValueDeltaPercent <= 10", "then": "low" },
      { "if": "changeCount <= 6 && maxValueDeltaPercent <= 25", "then": "medium" },
      { "default": "high" }
    ]
  },
  "reviewerPolicy": {
    "tier1": {
      "provider": "ollama",
      "model": "qwen3:14b",
      "fallbackModel": "llama3.1:8b",
      "endpoint": "http://127.0.0.1:11434",
      "timeoutSeconds": 60,
      "maxRetries": 2
    }
  },
  "reviewChecklist": [
    {
      "id": "note-nonempty",
      "ask": "각 변경 항목의 note가 비어 있지 않고 의미 있는 설명인가",
      "onFail": "needs_changes"
    },
    {
      "id": "after-matches-goal",
      "ask": "각 변경의 after 값이 note가 말하는 방향과 일치하는가",
      "onFail": "needs_changes"
    },
    {
      "id": "no-scope-creep",
      "ask": "changes에 blueprint 위반 해소와 무관한 항목이 섞여 있는가",
      "expect": false,
      "onFail": "escalate"
    }
  ],
  "executorPolicy": {
    "ladder": ["rule-engine"],
    "escalation": {
      "maxLocalRetries": 2,
      "requiresApprovalAbove": "rule-engine"
    },
    "tier1": {
      "provider": "ollama",
      "model": "qwen3:8b",
      "endpoint": "http://127.0.0.1:11434",
      "timeoutSeconds": 90,
      "maxRetries": 2
    },
    "maxRegenerations": 1
  },
  "checkpoints": [
    { "id": "loop-milestone", "on": "loopIteration", "every": 5, "action": "pause_notify" }
  ]
}
