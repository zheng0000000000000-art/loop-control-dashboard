e);\\n        for (var i = startIndex; i < args.Length; i++)\\n            if (args[i].StartsWith(\\\"--\\\", StringComparison.Ordinal) && i + 1 < args.Length)\\n            { map[args[i][2..]] = args[i + 1]; i++; }\\n        return map;\\n    }\\n\\n    // SHA-256을 소문자 hex로 계산한다.\\n    private static string ComputeSha256(string content)\\n        => Convert.ToHexString(SHA256.HashData(Encoding.UTF8.GetBytes(content))).ToLowerInvariant();\\n\\n    // stderr에 JSON 오류 메시지를 출력한다.\\n    private static void WriteError(string message)\\n        => Console.Error.WriteLine($\\\"{{\\\\\\\"error\\\\\\\":\\\\\\\"{message}\\\\\\\"}}\\\");\\n}\\n\",\"structuredPatch\":[{\"oldStart\":217,\"oldLines\":7,\"newStart\":217,\"newLines\":7,\"lines\":[\"         catch { return false; }\",\"     }\",\" \",\"-    // 선행조건 9: .claude/settings*.json에서 hooks 항목 유무로 자동 launcher 비활성을 판단한다. 파일 있음 + malformed JSON → fail-closed.\",\"+    // 선행조건 9: .claude/settings*.json에서 hooks 필드 유무로 자동 launcher 비활성을 판단한다. 파일 있음 + malformed JSON → fail-closed. hooks 필드가 존재하면 값이 무엇이든 fail-closed.\",\"     private static bool CheckAutoLauncherOff(string root)\",\"     {\",\"         foreach (var path in GetClaudeSettingsPaths(root))\"]},{\"oldStart\":226,\"oldLines\":7,\"newStart\":226,\"newLines\":7,\"lines\":[\"             try\",\"             {\",\"                 var node = JsonNode.Parse(File.ReadAllText(path, new System.Text.UTF8Encoding(false)));\",\"-                if (node?[\\\"hooks\\\"] is JsonObject hooks && hooks.Count > 0) return false;\",\"+                if (node is JsonObject obj && obj.ContainsKey(\\\"hooks\\\")) return false;\",\"             }\",\"             catch { return false; } // 파싱 불가 → 확인 불가 → fail-closed\",\"         }\"]}],\"userModified\":false,\"replaceAll\":false}}\noutputs/sonnet-06C-2-R3.out.jsonl:33:{\"type\":\"assistant\",\"message\":{\"model\":\"claude-sonnet-4-6\",\"id\":\"msg_011Cd1NkoSaHZ1iHEjGXMY1z\",\"type\":\"message\",\"role\":\"assistant\",\"content\":[{\"type\":