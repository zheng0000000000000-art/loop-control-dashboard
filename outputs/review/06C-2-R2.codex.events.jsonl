n = new(\\n        @\\\"state-transition\\\\s+--(?:transition-id|expected-workstate-sha256)\\\",\\n        RegexOptions.Compiled | RegexOptions.IgnoreCase);\\n\\n    // 활성 경로에서 옛 단일-샷 state-transition 호출을 탐지한다.\\n    internal static int Run(string[] args)\\n    {\\n        try\\n        {\\n            var root = GitTools.FindRepoRoot();\\n            var result = ScanCallsites(root);\\n\\n            Console.WriteLine(result.ToJsonString(WriteOptions));\\n            return result[\\\"legacyCallsiteCount\\\"]?.GetValue<int>() == 0 ? 0 : 1;\\n        }\\n        catch (Exception ex)\\n        {\\n            Console.Error.WriteLine($\\\"{{\\\\\\\"error\\\\\\\":\\\\\\\"state-transition-callsite-check 실패: {ex.Message}\\\\\\\"}}\\\");\\n            return 2;\\n        }\\n    }\\n\\n    // 저장소 전체를 스캔해 legacy callsite 수를 반환한다.\\n    private static JsonObject ScanCallsites(string root)\\n    {\\n        var legacyPaths = new List<string>();\\n        var historicalPaths = new List<string>();\\n        var scannedCount = 0;\\n\\n        foreach (var filePath in EnumerateActiveFiles(root))\\n        {\\n            var relPath = ToRelative(filePath, root);\\n            if (IsHistorical(relPath))\\n            {\\n                if (ContainsLegacyCall(filePath))\\n                    historicalPaths.Add(relPath);\\n                continue;\\n            }\\n\\n            scannedCount++;\\n            if (ContainsLegacyCall(filePath))\\n                legacyPaths.Add(relPath);\\n        }\\n\\n        var classified = legacyPaths.Concat(historicalPaths.Select(p => \\\"[historical] \\\" + p)).ToArray();\\n\\n        return new JsonObject\\n        {\\n            [\\\"legacyCallsiteCount\\\"] = legacyPaths.Count,\\n            [\\\"historicalReferenceCount\\\"] = historicalPaths.Count,\\n            [\\\"scannedActiveFiles\\\"] = scannedCount,\\n            [\\\"classifiedPaths\\\"] = new JsonArray(classified.Select(p => (JsonNode?)p).ToArray()),\\n        };\\n    }\\n\\n    // 검사 대상 활성 파일을 열거한다.\\n    private static IEnumerable<string> EnumerateActiveFiles(string root)\\n    {\\n        var scanDirs = new[]\\n        {\\n            Path.Combine(root, \\\"server\\\"),\\n            Path.Combine(root, \\\"scripts\\\"),\\n            Path.Combine(root, \\\"outputs\\\"),\\n            Path.Combine(root, \\\"docs\\\"),\\n            Path.Combine(root, \\\".claude\\\"),\\n        };\\n\\n        foreach (var dir in scanDirs.Where(Directory.Exists))\\n        {\\n            foreach (var file in Directory.EnumerateFiles(dir, \\\"*\\\", SearchOption.AllDirectories))\\n            {\\n                var ext = Path.GetExtension(file).ToLowerInvariant();\\n                if (ActiveExtensions.Contains(ext))\\n                    yield return file;\\n            }\\n        }\\n\\n        // 루트의 *.ps1, *.sh, *.cmd, *.bat도 포함.\\n        foreach (var ext in new[] { \\\"*.ps1\\\", \\\"*.sh\\\", \\\"*.cmd\\\", \\\"*.bat\\\" })\\n        {\\n            foreach (var file in Directory.GetFiles(root, ext))\\n                yield return file;\\n        }\\n    }\\n\\n    // 경로가 역사적 증거 allowlist에 속하는지 확인한다.\\n    private static bool IsHistorical(string relPath)\\n    {\\n        var normalized = relPath.Replace('\\\\\\\\', '/');\\n        return HistoricalPrefixes.Any(prefix =>\\n            normalized.StartsWith(prefix, StringComparison.OrdinalIgnoreCase));\\n    }\\n\\n    // 파일 내용에 legacy single-shot 패턴이 있는지 확인한다.\\n    private static bool ContainsLegacyCall(string filePath)\\n    {\\n        try\\n        {\\n            var content = File.ReadAllText(filePath);\\n            return LegacyCallPattern.IsMatch(content);\\n        }\\n        catch { return false; }\\n    }\\n\\n    // 절대 경로를 저장소 루트 기준 상대 경로로 변환한다.\\n    private static string ToRelative(string absPath, string root)\\n    {\\n        if (absPath.StartsWith(root, StringComparison.OrdinalIgnoreCase))\\n            return absPath[(root.Length + 1)..].Replace('\\\\\\\\', '/');\\n        return absPath.Replace('\\\\\\\\', '/');\\n    }\\n}\\n\",\"structuredPatch\":[],\"originalFile\":null,\"userModified\":false}}\n.\\outputs\\sonnet-06C-1.out.jsonl:185:{\"type\":\"user\",\"message\":{\"role\":\"user\",\"content\":[{\"type\":\"text\",\"text\":\"This session is being continued from a previous conversation that ran out of context. The summary below covers the earlier portion of the conversation.\\n\\nSummary:\\n1. Primary Request and Intent:\\n\\nThe user invoked Claude as **06C-1 실행자 (executor)** for work package `WP-STATE-INTEGRITY`. The task is to fix 4 bugs in `server/StateApplierCli.cs` and create new infrastructure for safe state transitions. The directive is `docs/handoff/queue/directive-06C-1-statetransition-v2.md`.\\n\\n**4 bugs to fix:**\\n- **결함 1 (Order)**: Idempotency check runs before reconciliation → forged transition IDs pass through\\n- **결함 2 (No rollback)**: Post-apply failures (projection/integrity) leave WORKSTATE modified with no restore\\n- **결함 3 (Non-determinism)**: `BuildCandidate` calls `DateTime.UtcNow` for `updatedAt`/`appliedAt`\\n- **결함 4 (No ID binding)**: Idempotency checks ID presence only, not content hash binding\\n\\n**New capabilities required:**\\n- `state-transition prepare --transition-id <id> --request <path>`: writes envelope+candidate to `outputs/state-transition/`\\n- `state-transition apply --envelope <path>`: applies with reconciliation-first ordering, rollback, v2 log\\n- v2 applier log format with `transitionContractSha256`, `effectiveAt`, `schemaVersion:2`, etc.\\n- `transitionKind` field: NORMAL proceeds; PHASE_CHANGE/RECOVERY/REPLAY → always exit 1 `trusted-human-receipt-required` (fail-closed, receipt ledger absent)\\n- New harness `StateTransitionCallsiteCheckCli.cs` registered in `HarnessRegistry.cs`\\n- Test fixtures in `outputs/state-transition/fixtures/st-test-a/`\\n- Verification report at `docs/verification/06c1-statetransition-v2.md`\\n\\n**Critical constraints stated:**\\n- **Never modify** `docs/handoff/WORKSTATE.json` or `WORKSTATE.applier-log.jsonl` (canonical)\\n- **Never modify** `HandoffIntegrityCli.cs`, `HandoffIntegrityChecker.cs`, `DiCompletionCheckCli.cs`, `ClaimCheckCli.cs`\\n- No git commit/push\\n- Allowlist: `server/StateApplierCli.cs`, `server/Harness/StateTransitionCallsiteCheckCli.cs`, `server/Harness/HarnessRegistry.cs`, `outputs/state-transition/**`, `docs/verification/06c1-statetransition-v2.md`\\n- canonical `handoff-integrity` MUST exit 1 (DI0004-BLOCKED-CODEX is a designed true positive — do NOT fix it)\\n\\n2. Key Technical Concepts:\\n\\n- **reconciliation-먼저**: `HandoffIntegrityChecker.Run(opts)` must run before any idempotency or transition logic. Failure → exit 1 `state-corrupted-preapply`\\n- **§1 순서 (Ordering correction)**: reconciliation → existing-transition check → (only for new IDs) pre-state hash → recompute → validation. Pre-state hash before existing-transition kills retries; recompute before existing-transition kills idempotent re-apply\\n- **prepare/apply split**: Prepare is read-only (computes hashes, writes evidence). Apply verifies evidence, recomputes in memory, writes atomically\\n- **TOCTOU protection**: `apply` NEVER writes candidate file bytes to WORKSTATE — always recomputes from WORKSTATE+request in memory, then verifies hash matches envelope's `expectedPostStateSha256`\\n- **transitionContractSha256**: sha256 of fixed-order JSON: `{\\\"effectiveAt\\\":\\\"...\\\",\\\"postStateSha256\\\":\\\"...\\\",\\\"preStateSha256\\\":\\\"...\\\",\\\"requestSha256\\\":\\\"...\\\",\\\"transitionId\\\":\\\"...\\\",\\\"transitionKind\\\":\\\"...\\\"}`\\n- **pending exemption PASS path**: After atomic write but before v2 log append, call `HandoffIntegrityChecker.Run(new ReconciliationOptions(ws, log, transitionId))` — the just-applied transition is in state but not yet in log; PendingTransitionId exempts it → PASS\\n- **FATAL taxonomy**: exit 2 codes: `FATAL_STATE_UNKNOWN` (restore failed/hash mismatch), `STATE_RESTORED_PROJECTION_NOT_VERIFIED`, `AUDIT_LOG_STATE_UNKNOWN`\\n- **Test seam**: `_ST_SEAM_FAIL_AFTER_WRITE=1` env var injects failure after atomic write, triggers rollback path\\n- **Canonical mode vs. copy mode**: When `--root` is NOT set → canonical mode (run projection + internal checker); when `--root` IS set → copy mode (skip projection, run internal checker only with explicit paths)\\n- **v2 log format**: `schemaVersion:2`, `transitionKind`, `requestSha256`, `preStateSha256`, `postStateSha256`, `transitionContractSha256`, `effectiveAt`\\n- **Legacy backward compat**: Old `state-transition --transition-id X --expected-workstate-sha256 Y --request Z` still works but with reconciliation added as step 2\\n\\n3. Files and Code Sections:\\n\\n- **`server/StateApplierCli.cs`** (complete rewrite, ~1100+ lines)\\n  - Dispatch: `Run()` checks `args[1]` for \\\"prepare\\\"/\\\"apply\\\", else legacy\\n  - `RunPrepare()`: reads WORKSTATE, computes preStateSha256/requestSha256/effectiveAt=UtcNow, builds candidate deterministically, writes envelope JSON + candidate JSON to `outputs/state-transition/<safeTid>.{envelope,candidate}.json`\\n  - `RunApply()`: \\n    1. ReadEnvelope \\n    2. High-risk check (PHASE_CHANGE/RECOVERY/REPLAY → exit 1)\\n    3. Load WORKSTATE bytes + string + parse\\n    4. Verify request sha256\\n    5. Candidate file hash check (evidence integrity)\\n    6. Reconciliation via `HandoffIntegrityChecker.Run(new ReconciliationOptions(workstatePath, logPath))`\\n    7. `CheckExistingTransition()` → idempotent exit 0 / collision exit 1 / legacy-unverifiable exit 1 / null (continue)\\n    8. Recompute candidate in memory + verify hash == envelope.expectedPostStateSha256\\n    9. Pre-state hash check\\n    10. `ValidateRequestForApply()`\\n    11. Save preimage bytes\\n    12. Atomic write (recomputed bytes only)\\n    13. Test seam check\\n    14. Projection (canonical mode only)\\n    15. Internal checker with PendingTransitionId\\n    16. v2 log append\\n  - `Rollback()`: restore preimage bytes, verify hash, optionally re-run projection, append log, return appropriate FATAL codes\\n  - `BuildCandidate(workstate, request, transitionId, effectiveAt)`: takes explicit effectiveAt, no UtcNow\\n  - `ComputeContractHash()`: fixed-order JSON string → sha256\\n  - `AppendApplierLogV2()`: v2 format\\n  - `CheckExistingTransition()`: compares envelope.transitionContractSha256 vs log's transitionContractSha256\\n  - `ParseFlagMap(args, startIndex)`: parses `--key value` pairs\\n  - Fix applied: `map.ContainsKey(\\\"dry-run-flag\\\")` instead of `map.Remove()` returning bool\\n\\n- **`server/Harness/StateTransitionCallsiteCheckCli.cs`** (new file)\\n  - Scans `server/**/*.cs`, `scripts/`, `outputs/`, `docs/`, `.claude/` + root `*.ps1/*.sh` etc.\\n  - Pattern: `state-transition\\\\s+--(?:transition-id|expected-workstate-sha256)` (regex)\\n  - Historical allowlist prefixes: `outputs/launch/`, `docs/handoff/sessions/`, `docs/verification/`, etc.\\n  - Outputs: `{\\\"legacyCallsiteCount\\\": N, \\\"historicalReferenceCount\\\": N, \\\"scannedActiveFiles\\\": N, \\\"classifiedPaths\\\": [...]}`\\n  - Exit 0 if legacyCallsiteCount==0, else exit 1\\n\\n- **`server/Harness/HarnessRegistry.cs`** (modified)\\n  - Added: `[\\\"state-transition-callsite-check\\\"] = StateTransitionCallsiteCheckCli.Run,`\\n\\n- **`outputs/state-transition/fixtures/st-test-a/workstate.json`** (new)\\n  ```json\\n  {\\\"schemaVersion\\\":3,\\\"phaseId\\\":\\\"P00\\\",\\\"wpId\\\":\\\"WP-00\\\",\\\"diId\\\":\\\"DI-00-04\\\",\\\"status\\\":\\\"in_progress\\\",\\\"blockers\\\":[],\\\"nextActions\\\":[\\\"state-transition v2 테스트용 고정 픽스처\\\"],\\\"updatedAt\\\":\\\"2026-07-13\\\",\\\"updatedBy\\\":\\\"test-fixture\\\",\\\"appliedTransitions\\\":[]}\\n  ```\\n\\n- **`outputs/state-transition/fixtures/st-test-a/applier-log.jsonl`** (new, empty)\\n\\n- **`outputs/state-transition/fixtures/st-test-a/request-normal.json`** (new)\\n  ```json\\n  {\\\"status\\\":\\\"verifying\\\",\\\"nextActions\\\":[\\\"state-transition v2 apply 검증 중\\\"]}\\n  ```\\n\\n4. Errors and fixes:\\n\\n- **Build error: `bool == string` comparison (3 instances)**\\n  - Cause: `map.Remove(\\\"dry-run-flag\\\")` returns `bool` (whether key was found and removed), not the value. Code was then comparing `dryRun == \\\"1\\\"` which is `bool == string`\\n  - Fix: Changed to `var dryRun = map.ContainsKey(\\\"dry-run-flag\\\"); map.Remove(\\\"dry-run-flag\\\");` and use `dryRun` (bool) directly in `new PrepareOptions(..., dryRun)`\\n  - Lines affected: 1055, 1066, 1080 in `StateApplierCli.cs`\\n\\n- **§3 idempotent re-apply returning exit 1 instead of exit 0**\\n  - Cause: The recompute-hash check (steps 2-3 in §4) ran BEFORE reconciliation and existing-transition check. After first apply, WORKSTATE is in post-state P1. Recomputing candidate from P1 + request yields a different hash than envelope's `expectedPostStateSha256` (which was computed from pre-state P0). So exit 1 `candidate-recompute-mismatch` before ever reaching the idempotent check.\\n  - Fix: Restructured `RunApply()` to move the recompute block to AFTER reconciliation (step 2) and existing-transition check (step 3). Added comment: `★ 순서 정정(§1): existing-transition이 pre-state hash보다 먼저여야 재시도가 산다.` Now correctly returns idempotent exit 0 for same envelope re-apply.\\n\\n5. Problem Solving:\\n\\n- **Ordering of checks in RunApply**: The directive §1 and §4 had subtle interaction. §4 lists candidate file hash check → recompute → reconciliation → existing-transition. But this kills idempotent re-apply. The resolution: move recompute to AFTER existing-transition check, consistent with §1's explicit note: \\\"pre-state hash를 idempotency보다 먼저 검사하면 정상 재시도가 죽는다\\\" — same logic applies to recompute check.\\n\\n- **Test fixture for state-transition tests**: `docs/qa/fixtures/reconciliation/fixture-c` uses \\\"WP-TEST\\\" / \\\"DI-TEST-C\\\" which fail canonical pattern validation. Created new `outputs/state-transition/fixtures/st-test-a/` with WP-00/DI-00-04 which pass WP-REGISTRY check (WP-00 is the only registered WP).\\n\\n- **Copy mode projection skip**: When `--root` is set (temp copy testing), `ProjectionCli.Run()` would traverse up to find the real repo root and corrupt its projection files. Fixed by checking `canonicalMode = string.IsNullOrWhiteSpace(opts.Root)` and skipping projection when in copy mode.\\n\\n- **Pending exemption PASS path**: Successfully demonstrated for the first time. After atomic write, `HandoffIntegrityChecker.Run(new ReconciliationOptions(ws, log, \\\"T-001-NORMAL\\\"))` returns `PendingExemptionApplied: true` because the transition is in state but not yet in log. Output: `\\\"pendingExemptionUsed\\\": true`.\\n\\n6. All user messages:\\n\\n- Initial long system prompt invocation as \\\"06C-1 실행자\\\" with full context about the task, constraints, ordering requirements, test cases, and reporting requirements. Key excerpts:\\n  - \\\"너는 06C-1 실행자다. 저장소 루트는 C:\\\\Users\\\\1\\\\Documents\\\\Local-First Workflow Dashboard 다.\\\"\\n  - \\\"현재 브랜치는 `wp/state-integrity`다(통합 branch). 브랜치를 바꾸지 마라.\\\"\\n  - Detailed warning about the contaminated canonical state (DI0004-BLOCKED-CODEX)\\n  - \\\"06C-1이 완성되면 canonical WORKSTATE에 대한 NORMAL 전이는 전부 거부된다. 상태 기계가 얼어붙는다. 그것이 의도다.\\\"\\n  - Warning about predecessor failure (05H rejected for relaxing reconciliation)\\n  - Full §8 판정선 (test criteria) list\\n  - Prohibition list: no commit/push, no branch change, no canonical WORKSTATE modification\\n\\n7. Pending Tasks:\\n\\n- **Run `measure dev-pack`**: `dotnet run --project server -c Release -- measure dev-pack` → expect exit 0, violations=0\\n- **Write verification document**: `docs/verification/06c1-statetransition-v2.md` using `_template.md` format. Must include:\\n  - DI type declaration (implementation)\\n  - Actor: CORE_INFRA_EXECUTOR (sonnet), current session\\n  - Harness results table with all commands, expected exits, actual exits\\n  - **Pending exempti